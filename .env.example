# Copy to apps/api/.env and apps/web/.env as needed

# API
# SQLite (default dev): DB file at apps/api/prisma/dev.db (gitignored).
# If `prisma` CLI errors about file:, unset a conflicting shell/system DATABASE_URL.
DATABASE_URL="file:./dev.db"
# Leave empty for local dev without Docker; set to redis://localhost:6379 when Redis is up
REDIS_URL=
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long!!
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars!!
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
APP_URL=http://localhost:5173
API_URL=http://localhost:3000
API_PREFIX=api

# SMTP (optional for dev; logs to console if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@example.com

# Uploads
UPLOAD_DIR=./uploads

# Web (Vite)
VITE_API_URL=http://localhost:3000/api
